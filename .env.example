# Copy this file to `.env` and adjust values for your setup.
# Paths below are container paths, not Windows host paths.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint works: LM Studio, Ollama, vLLM, llama.cpp, OpenAI...
# From inside Docker on Windows/macOS, `host.docker.internal` usually points to the host.
# If your LLM runs remotely, put the full remote base URL here.
# Expected API shape: POST {LLM_URL}/chat/completions
LLM_URL=http://host.docker.internal:1234/v1
# Model name passed to the upstream chat completions API.
LLM_MODEL=local-model

# ── Whisper (STT) ─────────────────────────────────────────────────────────────
# Directory with the CTranslate2-exported faster-whisper model.
# See `models/README.md` for the required folder contents.
WHISPER_PATH=/app/models/faster-whisper-turbo
# `float16` = best quality, uses more VRAM.
# `int8`    = lower VRAM usage, usually with minimal quality loss.
# Use `int8` first if you hit VRAM pressure.
WHISPER_COMPUTE_TYPE=float16

# ── F5-TTS ────────────────────────────────────────────────────────────────────
# Main F5-TTS checkpoint and vocabulary files.
# These must exist inside the mounted `/app/models/...` directory in the container.
F5_MODEL_PATH=/app/models/f5tts-russian/model_last_inference.safetensors
F5_VOCAB_PATH=/app/models/f5tts-russian/vocab.txt

# ── Voices ────────────────────────────────────────────────────────────────────
# Directory with voice profile folders.
# Each voice must be a subfolder containing:
#   - ref.wav : reference audio
#   - ref.txt : exact transcript of that audio
# The service falls back to DEFAULT_VOICE if a requested voice is missing.
VOICES_DIR=/app/models/voices
# Must exist, because startup warmup uses this voice.
DEFAULT_VOICE=default

# ── LLM behaviour ─────────────────────────────────────────────────────────────
# If this file exists, it overrides SYSTEM_PROMPT below.
# Useful when you want to keep long prompts outside `.env`.
SYSTEM_PROMPT_FILE=/app/system_prompt.txt
# Fallback prompt used only when SYSTEM_PROMPT_FILE is missing.
SYSTEM_PROMPT=Ты голосовой ассистент. Отвечай кратко и разговорно.

# ── Session / Redis ───────────────────────────────────────────────────────────
# Redis connection string used for chat session persistence.
REDIS_URL=redis://redis:6379
# How long to keep a chat session in Redis, in seconds.
SESSION_TTL=3600
# Max stored user/assistant turns per session history.
# Larger values preserve more context but increase payload size sent to the LLM.
HISTORY_MAX_TURNS=20
