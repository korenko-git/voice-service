# ── LLM ──────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint: LM Studio, Ollama, vLLM, llama.cpp, OpenAI…
# From inside Docker on Windows/macOS use host.docker.internal as the hostname.
LLM_URL=http://host.docker.internal:1234/v1
LLM_MODEL=local-model

# ── Whisper (STT) ─────────────────────────────────────────────────────────────
WHISPER_PATH=/app/models/faster-whisper-turbo
# float16 = best quality (~1.5 GB VRAM) | int8 = saves ~700 MB, minimal loss
WHISPER_COMPUTE_TYPE=float16

# ── F5-TTS ────────────────────────────────────────────────────────────────────
F5_MODEL_PATH=/app/models/f5tts-russian/model_last_inference.safetensors
F5_VOCAB_PATH=/app/models/f5tts-russian/vocab.txt

# ── Voices ────────────────────────────────────────────────────────────────────
# Directory containing voice profile folders (each with ref.wav + ref.txt)
VOICES_DIR=/app/models/voices
DEFAULT_VOICE=default

# ── LLM behaviour ─────────────────────────────────────────────────────────────
SYSTEM_PROMPT_FILE=/app/system_prompt.txt

# ── Session / Redis ───────────────────────────────────────────────────────────
SESSION_TTL=3600
HISTORY_MAX_TURNS=20